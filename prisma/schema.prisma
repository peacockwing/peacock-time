generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BabyLog {
  id                BigInt    @id @default(autoincrement())
  family_code       String
  category_code     String
  category_name_han String
  event_value       String
  event_date        String
  event_time        String
  display_emoji     String?
  actor_email       String?
  created_at        DateTime? @default(now()) @db.Timestamptz(6)

  @@index([event_date(sort: Desc), event_time(sort: Desc)], map: "baby_log_event_datetime_idx")
  @@index([family_code])
  @@map("baby_log")
}

model Checklist {
  id           BigInt    @id @default(autoincrement())
  family_code  String
  period_type  String
  task_name    String
  tips         String?
  is_completed Int       @default(0)
  created_at   DateTime? @default(now()) @db.Timestamptz(6)

  @@index([family_code])
  @@map("checklist")
}

model Inventory {
  id            BigInt    @id @default(autoincrement())
  family_code   String
  section_name  String
  item_name     String
  brand_name    String?
  target_cnt    Int       @default(1)
  status        String    @default("READY")
  memo          String?
  hotdeal_price Int?
  created_at    DateTime? @default(now()) @db.Timestamptz(6)

  @@index([family_code])
  @@map("inventory")
}

// Managed via Supabase auth/RLS directly (not queried through Prisma Client).
// Declared here so `prisma db push` recognizes the table and does not try to drop it.
model UserProfile {
  id          String   @id @db.Uuid
  family_code String
  user_name   String?
  email       String?  @unique(map: "user_profiles_email_idx")
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  @@index([family_code])
  @@map("user_profiles")
}
