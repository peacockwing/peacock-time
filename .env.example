## Copy to .env.local (do NOT commit secrets to git)
DATABASE_URL=postgresql://user:password@localhost:5432/peacock_time
# If you use Supabase Postgres, you can also set SUPABASE_DB_URL instead of DATABASE_URL.
# DATABASE_URL is still preferred.
SUPABASE_DB_URL=
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used by /api/photo-analysis (formula bottle / diaper photo auto-fill).
ANTHROPIC_API_KEY=your-anthropic-api-key

# Production note:
# DATABASE_URL should point to your production Postgres instance.
# If you are using Supabase for Prisma data, use the Supabase Postgres connection string
# (prefer the connection pooler host, e.g. *.pooler.supabase.com — the direct
# db.<ref>.supabase.co host is IPv6-only and may be unreachable), not the Supabase HTTP URL.
