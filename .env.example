## Copy to .env.local (do NOT commit secrets to git)
SOCKET_SECRET=replace-with-a-secure-random-value
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
SOCKET_PORT=3001
DATABASE_URL=postgresql://user:password@localhost:5432/peacock_time
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
REDIS_URL=redis://redis:6379

# Production note:
# DATABASE_URL should point to your production Postgres instance.
# If you are using Supabase for Prisma data, use the Supabase Postgres connection string,
# not the Supabase HTTP URL.
